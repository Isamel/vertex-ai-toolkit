# Vertex AI Toolkit — Configuration
# Copy to .env and adjust values

# ── GCP Settings ──────────────────────────────────────────
VAIG_GCP_PROJECT_ID=my-gcp-project
VAIG_GCP_LOCATION=us-central1

# ── Authentication ────────────────────────────────────────
# Mode: "adc" (default in Pod) | "impersonate"
VAIG_AUTH_MODE=adc
# Required only when AUTH_MODE=impersonate (local dev)
VAIG_IMPERSONATE_SA=my-sa@my-gcp-project.iam.gserviceaccount.com

# ── Model Defaults ────────────────────────────────────────
VAIG_DEFAULT_MODEL=gemini-2.5-pro
VAIG_FALLBACK_MODEL=gemini-2.5-flash
VAIG_TEMPERATURE=0.7
VAIG_MAX_OUTPUT_TOKENS=8192

# ── Session Persistence ──────────────────────────────────
VAIG_SESSION_DB_PATH=~/.vaig/sessions.db

# ── Skills ────────────────────────────────────────────────
# Comma-separated list of enabled skills
VAIG_ENABLED_SKILLS=rca,anomaly,migration

# ── Custom Skills Directory (optional) ────────────────────
# VAIG_CUSTOM_SKILLS_DIR=~/.vaig/skills
