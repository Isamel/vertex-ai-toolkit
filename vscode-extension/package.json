{
  "name": "vaig-vscode",
  "displayName": "VAIG — Vertex AI Infrastructure Guardian",
  "description": "Connect to a running VAIG server, stream live infrastructure diagnostics, and view reports — all inside VS Code.",
  "version": "0.1.0",
  "publisher": "vaig",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vaig.connect",
        "title": "VAIG: Connect to Server"
      },
      {
        "command": "vaig.liveDiagnosis",
        "title": "VAIG: Run Live Diagnosis"
      },
      {
        "command": "vaig.openReport",
        "title": "VAIG: Open Last Report"
      }
    ],
    "configuration": {
      "title": "VAIG",
      "properties": {
        "vaig.serverUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "URL of the VAIG server."
        },
        "vaig.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically connect to the VAIG server on startup."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "test": "vitest run",
    "pretest": "npm run compile"
  },
  "dependencies": {
    "eventsource-parser": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/vscode": "1.85.0",
    "@vscode/test-electron": "^2.3.8",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
