<?xml version="1.0" encoding="UTF-8"?>
<!--
  Shared database connection definitions for Pentaho Data Integration.
  Referenced by all transformations and jobs via connection name.
-->
<shared-connections>

  <!-- ── Warehouse (target) ── -->
  <connection>
    <name>warehouse_db</name>
    <server>${DB_HOST}</server>
    <type>POSTGRESQL</type>
    <access>Native</access>
    <database>${DB_NAME}</database>
    <port>${DB_PORT}</port>
    <username>${DB_USER}</username>
    <password>${DB_PASSWORD}</password>
    <attributes>
      <attribute>
        <code>INITIAL_POOL_SIZE</code>
        <attribute>5</attribute>
      </attribute>
      <attribute>
        <code>MAXIMUM_POOL_SIZE</code>
        <attribute>20</attribute>
      </attribute>
      <attribute>
        <code>IS_CLUSTERED</code>
        <attribute>N</attribute>
      </attribute>
      <attribute>
        <code>USE_POOLING</code>
        <attribute>Y</attribute>
      </attribute>
    </attributes>
  </connection>

  <!-- ── Inventory source (read-only) ── -->
  <connection>
    <name>inventory_db</name>
    <server>${INVENTORY_DB_HOST}</server>
    <type>POSTGRESQL</type>
    <access>Native</access>
    <database>${INVENTORY_DB_NAME}</database>
    <port>${INVENTORY_DB_PORT}</port>
    <username>${INVENTORY_DB_USER}</username>
    <password>${INVENTORY_DB_PASSWORD}</password>
    <attributes>
      <attribute>
        <code>USE_POOLING</code>
        <attribute>Y</attribute>
      </attribute>
      <attribute>
        <code>MAXIMUM_POOL_SIZE</code>
        <attribute>10</attribute>
      </attribute>
    </attributes>
  </connection>

</shared-connections>
